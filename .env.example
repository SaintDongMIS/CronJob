# 複製為 .env：cp .env.example .env
# 勿將含 ERP_COOKIE 的 .env 提交版本庫

ERP_LIST_URL=

# ERP_COOKIE=
# ERP_DELAY_SEC=5
# ERP_DRY_RUN=0
# ERP_UPDATE_REL_PATH=update_balance_status.asp
# ERP_FILTER_STATUS=沒有在鼎新
# ERP_REQUEST_TIMEOUT_SEC=120

# --- 環景檔案瀏覽器 ToBim（scripts/tobim_copy_images_gps.py）---
# ASSETS_BASE_URL=   # 選填，預設 http://assets.bim-group.com:9880
# TOBIM_DRY_RUN=1    # 本機建議 1；未設定時本機預設 dry-run、Actions 預設正式執行
# 其餘 TOBIM_* 使用腳本預設（DELAY 2s、REQUIRE_CSV 1、timeout 120/3600），不必寫入 .env

# --- 排程健康檢查 Email ---
# GitHub Actions：scripts/workflow_health_email.py（需 GITHUB_TOKEN）
# NAS cron：scripts/nas_health_email.py（讀 logs/erp_*.log、logs/tobim_*.log）
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# EMAIL_TO=
# DIGEST_DRY_RUN=1
# NAS_LOG_DIR=       # 選填，預設 <專案>/logs
# NAS_HOSTNAME=      # 選填，郵件內顯示的主機名
