# 複製為 .env：cp .env.example .env
# 勿將含 ERP_COOKIE 的 .env 提交版本庫

ERP_LIST_URL=

# ERP_COOKIE=
# ERP_DELAY_SEC=5
# ERP_DRY_RUN=0
# ERP_UPDATE_REL_PATH=update_balance_status.asp
# ERP_FILTER_STATUS=沒有在鼎新
# ERP_REQUEST_TIMEOUT_SEC=120

# --- 環景檔案瀏覽器 ToBim（scripts/tobim_copy_images_gps.py）---
# ASSETS_BASE_URL=   # 選填，預設 http://assets.bim-group.com:9880
# TOBIM_DRY_RUN=1    # 本機建議 1；未設定時本機預設 dry-run、Actions 預設正式執行
# TOBIM_PAUSED=1     # 1=暫停（印 SKIP 已暫停，健康檢查顯示 ⏭）
# TOBIM_PROBE_TIMEOUT_SEC=5  # API 連線探測逾時（秒）；連不上則略過，健康檢查顯示 🟡
# TOBIM_DELAY_SEC=5          # 巷與巷之間間隔（秒）；預設 5
# TOBIM_RUN_BUDGET_SEC=2700  # 每輪 COPY 階段時間預算（秒）；0=關閉，改回僅靠 MAX_COPY
# TOBIM_MAX_COPY_PER_RUN=0    # 每輪最多 COPY 幾巷；0=不限制（預設，搭配時間預算）
# SHOULD_RUN_STRICT=1        # NAS run_tobim.sh 已帶；非執行窗 SKIP 時 exit 1
# 其餘 TOBIM_* 使用腳本預設（REQUIRE_CSV 1、timeout 120/3600），不必寫入 .env

# --- 排程健康檢查（NAS）---
# Email：scripts/nas_health_email.py（早晚摘要）
# Telegram：scripts/nas_health_check.py（每 2 小時輪詢，預設僅異常時發送）
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# EMAIL_TO=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# HEALTH_NOTIFY_OK=0       # 已廢止；Telegram 固定每次回報 job 結果
# HEALTH_SKIP_HOLIDAY=1    # 1=放假日 Telegram 略過
# HEALTH_GRACE_MIN=5         # ERP：START 後幾分鐘內不計異常
# HEALTH_GRACE_MIN_TOBIM=15  # ToBim：預設 15；有 COPY 活動時最長寬限 50 分
# HEALTH_WINDOW_HOURS=2    # Telegram 統計過去 N 小時
# DIGEST_DRY_RUN=1
# NAS_LOG_DIR=             # 選填，預設 <專案>/logs
# NAS_HOSTNAME=            # 選填，訊息內顯示的主機名
